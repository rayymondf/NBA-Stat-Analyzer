# Get a free key at https://aistudio.google.com -> "Get API key"
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-flash-latest

# Free-tier efficiency controls (these are also the built-in defaults)
AI_RESPONSE_CACHE=1
AI_RESPONSE_CACHE_TTL=43200
AI_MAX_REMOTE_CALLS=6
AI_MAX_OUTPUT_TOKENS=1600
AI_THINKING_LEVEL=low
